# ============================================================
# 環境変数のテンプレート
# ============================================================
# このファイルをコピーして .env にリネームし、実際の値を入れて使う。
# .env は .gitignore により Git 管理から除外されている。

# ----------------------------------------------------------------
# 必須: データベース接続
# ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_NAME=taskmanager_dev
DB_USER=taskmanager_dev
DB_PASSWORD=dev

# ----------------------------------------------------------------
# 必須: JWT 認証
# ----------------------------------------------------------------
# 本番では以下のコマンドでランダムな値を生成して使う:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------------------------------------------
# 任意: AWS Parameter Store の利用（本番のみ）
# ----------------------------------------------------------------
# true にすると Parameter Store から秘密情報を取得する。
# 本番（AWS EC2）では以下を設定する:
#   USE_PARAMETER_STORE=true
#   AWS_REGION=ap-northeast-1
#   PARAM_STORE_PREFIX=/taskmanager/prod
USE_PARAMETER_STORE=false
AWS_REGION=ap-northeast-1
PARAM_STORE_PREFIX=/taskmanager/prod
